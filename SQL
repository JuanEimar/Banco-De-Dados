CREATE DATABASE SIMP_DBB;

USE SIMP_DBB;

CREATE TABLE maquinas (
    id_maquina INT AUTO_INCREMENT PRIMARY KEY,
    nome_maquina VARCHAR(100) NOT NULL,
    descricao VARCHAR(200)
);

CREATE TABLE sensores (
    id_sensor INT AUTO_INCREMENT PRIMARY KEY,
    id_maquina INT,
    tipo_sensor VARCHAR(50),
    unidade_medida VARCHAR(20),

    FOREIGN KEY (id_maquina)
    REFERENCES maquinas(id_maquina)
);

CREATE TABLE operadores (
    id_operador INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    turno VARCHAR(20)
);

CREATE TABLE leituras (
    id_leitura INT AUTO_INCREMENT PRIMARY KEY,
    id_sensor INT,
    valor DECIMAL(5,2),
    data_leitura DATETIME,

    FOREIGN KEY (id_sensor)
    REFERENCES sensores(id_sensor)
);

CREATE TABLE alertas (
    id_alerta INT AUTO_INCREMENT PRIMARY KEY,
    id_leitura INT,
    nivel_alerta VARCHAR(20),
    mensagem VARCHAR(200),
    data_alerta DATETIME,

    FOREIGN KEY (id_leitura)
    REFERENCES leituras(id_leitura)
);

CREATE TABLE manutencoes (
    id_manutencao INT AUTO_INCREMENT PRIMARY KEY,
    id_maquina INT,
    id_operador INT,
    descricao VARCHAR(200),
    data_manutencao DATETIME,

    FOREIGN KEY (id_maquina)
    REFERENCES maquinas(id_maquina),

    FOREIGN KEY (id_operador)
    REFERENCES operadores(id_operador)
);

